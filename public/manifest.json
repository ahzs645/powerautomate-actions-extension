{
  "name": "Power Automate Toolkit",
  "description": "Record, copy, and manage Power Automate actions. Edit flow definitions as JSON with validation.",
  "version": "2.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_title": "Open the popup"
  },
  "icons": {
    "16": "logo16.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "permissions": [
    "activeTab",
    "webRequest",
    "background",
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "tabs",
    "notifications"
  ],
  "background": {
    "service_worker": "./static/js/background.js"
  },
  "host_permissions": [
    "https://*/*",
    "*://*.api.flow.microsoft.com/*",
    "*://*.api.powerautomate.com/*",
    "*://*.api.powerapps.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "./static/js/content.js"
      ],
      "all_frames": true
    }
  ]
}
